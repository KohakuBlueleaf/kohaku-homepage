---
import Base from "@/layouts/Base.astro";
import Hero from "@/components/Hero.vue";
import RecentProjects from "@/components/RecentProjects.vue";
import RecentPublications from "@/components/RecentPublications.vue";
import RecentCareer from "@/components/RecentCareer.vue";
import RecentPosts from "@/components/RecentPosts.vue";
import { AppConfig } from "@/utils/AppConfig.js";

import { getRecentProjects } from "@/config/projects.js";
import { getRecentPublications } from "@/config/publications.js";
import { getRecentCareers } from "@/config/careers.js";

// Get recent data
const recentProjects = getRecentProjects(6);
const recentPublications = getRecentPublications(3);
const recentCareers = getRecentCareers(2);

// Get recent posts
const postModules = import.meta.glob("./posts/*.md", { eager: true });
const allPosts = Object.values(postModules);
const recentPosts = allPosts
  .sort((a, b) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime())
  .slice(0, 3);

const title = "Kohaku's Homepage";
const description = AppConfig.description;
---

<Base head={{ title, description }}>
  <Hero client:load />

  <RecentProjects
    projects={recentProjects}
    client:visible
  />

  <RecentPublications
    publications={recentPublications}
    client:visible
  />

  <RecentCareer
    careers={recentCareers}
    client:visible
  />

  <RecentPosts
    posts={recentPosts}
    client:visible
  />
</Base>
